---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/layout/Header.astro';
import Footer from '../components/layout/Footer.astro';
import ProjectCard from '../components/project/ProjectCard.astro';
import { getCollection } from 'astro:content';

const allProjects = await getCollection('projects', (p) => p.data.published);
const featuredProjects = allProjects
  .sort((a, b) => b.data.year - a.data.year)
  .slice(0, 3);

const skills = [
  {
    icon: '🏗️',
    title: 'Distributed Systems',
    desc: 'Fault-tolerant, low-latency services at scale; real-time data pipelines and platform engineering',
  },
  {
    icon: '📊',
    title: 'Data & Analytics',
    desc: 'End-to-end data pipelines, developer workflow analytics, Airflow, Athena, Redshift, Quicksight',
  },
  {
    icon: '🤖',
    title: 'AI / ML Engineering',
    desc: 'Building AI-powered developer tools, intelligent insights platforms, and ML-backed workflow systems',
  },
  {
    icon: '🛠️',
    title: 'Developer Tools',
    desc: 'Internal platforms, productivity tooling, CI/CD infrastructure, and metrics-driven engineering',
  },
];
---

<BaseLayout title="Francis Sabado — Software Engineer & AI Engineer">
  <Header currentPath="/" />

  <main class="pt-20">
    <!-- ── Hero ─────────────────────────────────────── -->
    <section class="py-24 sm:py-32">
      <div class="site-container">
        <div class="flex flex-col md:flex-row items-center gap-12 lg:gap-20">
          <!-- Text -->
          <div class="flex-1 text-center md:text-left">
            <p class="text-sm font-semibold text-blue-600 dark:text-blue-400 uppercase tracking-wider mb-3">
              Portfolio
            </p>
            <h1
              class="text-4xl sm:text-5xl lg:text-6xl font-bold text-slate-900 dark:text-slate-100 mb-4 leading-tight"
            >
              Francis Sabado
            </h1>
            <p class="text-lg sm:text-xl text-slate-500 dark:text-slate-400 mb-6 font-medium">
              Software Engineer · AI Engineer · Researcher
            </p>
            <p
              class="text-base sm:text-lg text-slate-600 dark:text-slate-300 mb-6 leading-relaxed max-w-xl"
            >
              Senior Software Engineer with 10+ years building scalable systems, developer platforms,
              and mission-critical software across industry, research, and government. PhD in
              Computer Engineering.
            </p>

            <!-- Company highlights -->
            <div class="flex flex-wrap items-center gap-3 mb-8 justify-center md:justify-start">
              <!-- Lyft (current) -->
              <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-semibold bg-pink-100 text-pink-800 dark:bg-pink-900/30 dark:text-pink-300 ring-1 ring-pink-200 dark:ring-pink-700">
                <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M11.875 0c-1.512 0-2.737 1.225-2.737 2.737v7.588a3.25 3.25 0 0 1-3.25 3.25h-.476A1.412 1.412 0 0 0 4 14.987v2.45c0 .78.632 1.412 1.412 1.412h.476c3.35 0 6.062-2.622 6.237-5.925V2.737A2.737 2.737 0 0 0 11.875 0zm6.713 5.063a2.737 2.737 0 0 0-2.738 2.737v6.775H14.437a1.412 1.412 0 0 0-1.412 1.412v1.276c0 .78.632 1.412 1.412 1.412h1.413c2.35 0 4.15-1.8 4.15-4.15V7.8a2.737 2.737 0 0 0-2.738-2.737h-.674zM4.887 20.15A1.925 1.925 0 1 0 4.887 24a1.925 1.925 0 0 0 0-3.85z"/></svg>
                <span class="w-1.5 h-1.5 rounded-full bg-pink-500 animate-pulse shrink-0"></span>
                Lyft
              </span>
              <!-- Amazon -->
              <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-semibold bg-orange-100 text-orange-800 dark:bg-orange-900/30 dark:text-orange-300 ring-1 ring-orange-200 dark:ring-orange-700">
                <svg role="img" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" width="13" height="13" fill="currentColor" aria-hidden="true"><path d="M.045 18.02c.072-.116.187-.124.348-.022 3.636 2.11 7.594 3.166 11.87 3.166 2.852 0 5.668-.533 8.447-1.595l.315-.14c.138-.06.234-.1.293-.13.226-.088.39-.046.525.13.12.174.09.336-.12.48-.256.19-.6.41-1.006.654-1.244.743-2.64 1.316-4.185 1.726a17.617 17.617 0 01-10.951-.577 17.88 17.88 0 01-5.43-3.35c-.1-.074-.151-.15-.151-.22 0-.047.021-.09.051-.13zm6.565-6.218c0-1.005.247-1.863.743-2.577.495-.71 1.17-1.25 2.04-1.615.796-.335 1.756-.575 2.912-.72.39-.046 1.033-.103 1.92-.174v-.37c0-.93-.105-1.558-.3-1.875-.302-.43-.78-.65-1.44-.65h-.182c-.48.046-.896.196-1.246.46-.35.27-.575.63-.675 1.096-.06.3-.206.465-.435.51l-2.52-.315c-.248-.06-.372-.18-.372-.39 0-.046.007-.09.022-.15.247-1.29.855-2.25 1.82-2.88.976-.616 2.1-.975 3.39-1.05h.54c1.65 0 2.957.434 3.888 1.29.135.15.27.3.405.48.12.165.224.314.283.45.075.134.15.33.195.57.06.254.105.42.135.51.03.104.062.3.076.615.01.313.02.493.02.553v5.28c0 .376.06.72.165 1.036.105.313.21.54.315.674l.51.674c.09.136.136.256.136.36 0 .12-.06.226-.18.314-1.2 1.05-1.86 1.62-1.963 1.71-.165.135-.375.15-.63.045a6.062 6.062 0 01-.526-.496l-.31-.347a9.391 9.391 0 01-.317-.42l-.3-.435c-.81.886-1.603 1.44-2.4 1.665-.494.15-1.093.227-1.83.227-1.11 0-2.04-.343-2.76-1.034-.72-.69-1.08-1.665-1.08-2.94l-.05-.076zm3.753-.438c0 .566.14 1.02.425 1.364.285.34.675.512 1.155.512.045 0 .106-.007.195-.02.09-.016.134-.023.166-.023.614-.16 1.08-.553 1.424-1.178.165-.28.285-.58.36-.91.09-.32.12-.59.135-.8.015-.195.015-.54.015-1.005v-.54c-.84 0-1.484.06-1.92.18-1.275.36-1.92 1.17-1.92 2.43l-.035-.02zm9.162 7.027c.03-.06.075-.11.132-.17.362-.243.714-.41 1.05-.5a8.094 8.094 0 011.612-.24c.14-.012.28 0 .41.03.65.06 1.05.168 1.172.33.063.09.099.228.099.39v.15c0 .51-.149 1.11-.424 1.8-.278.69-.664 1.248-1.156 1.68-.073.06-.14.09-.197.09-.03 0-.06 0-.09-.012-.09-.044-.107-.12-.064-.24.54-1.26.806-2.143.806-2.64 0-.15-.03-.27-.087-.344-.145-.166-.55-.257-1.224-.257-.243 0-.533.016-.87.046-.363.045-.7.09-1 .135-.09 0-.148-.014-.18-.044-.03-.03-.036-.047-.02-.077 0-.017.006-.03.02-.063v-.06z"/></svg>
                Amazon
              </span>
              <!-- Sandia National Labs -->
              <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-sm font-semibold bg-slate-100 text-slate-700 dark:bg-slate-700/50 dark:text-slate-300 ring-1 ring-slate-200 dark:ring-slate-600">
                <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
                </svg>
                Sandia National Labs
              </span>
            </div>

            <div class="flex flex-wrap gap-4 justify-center md:justify-start">
              <a href="/portfolio/" class="btn-primary">View Portfolio</a>
              <a href="/resume/" class="btn-secondary">View Resume</a>
            </div>
          </div>

          <!-- Photo -->
          <div class="shrink-0">
            <div
              class="w-44 h-44 sm:w-56 sm:h-56 rounded-full overflow-hidden ring-4 ring-white dark:ring-slate-700 shadow-2xl"
            >
              <img
                src="/images/headshot.jpg"
                alt="Francis Sabado"
                class="w-full h-full object-cover object-top"
                loading="eager"
                decoding="async"
              />
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ── Expertise ───────────────────────────────── -->
    <section class="py-16 bg-slate-50 dark:bg-slate-800/30 transition-colors">
      <div class="site-container">
        <h2 class="section-title">Expertise</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
          {
            skills.map(({ icon, title, desc }) => (
              <div class="card p-6 hover:shadow-md transition-shadow">
                <div class="text-3xl mb-4">{icon}</div>
                <h3 class="text-base font-bold text-slate-900 dark:text-slate-100 mb-2">{title}</h3>
                <p class="text-sm text-slate-500 dark:text-slate-400 leading-relaxed">{desc}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- ── Featured Projects ──────────────────────── -->
    <section class="py-16">
      <div class="site-container">
        <div class="flex justify-between items-center mb-8">
          <h2 class="section-title mb-0">Featured Projects</h2>
          <a href="/portfolio/" class="btn-secondary text-sm">View all →</a>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </section>

    <!-- ── Quick Stats ────────────────────────────── -->
    <section class="py-16 bg-slate-50 dark:bg-slate-800/30 transition-colors">
      <div class="site-container">
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-8 text-center">
          {
            [
              { value: '10+', label: 'Years Industry Exp.' },
              { value: 'PhD', label: 'Computer Engineering' },
              { value: '3', label: 'Top Companies' },
              { value: '4', label: 'Conference Publications' },
            ].map(({ value, label }) => (
              <div>
                <div class="text-3xl sm:text-4xl font-bold text-blue-600 dark:text-blue-400 mb-1">
                  {value}
                </div>
                <div class="text-sm text-slate-500 dark:text-slate-400">{label}</div>
              </div>
            ))
          }
        </div>
      </div>
    </section>
  </main>

  <Footer />
</BaseLayout>
