---
// Search data is passed as a JSON string so it can be used by the client-side script
interface Props {
  searchData: string;
}

const { searchData } = Astro.props;
---

<div id="search-container" class="relative w-full max-w-lg">
  <div class="relative">
    <svg
      class="absolute left-3 top-1/2 -translate-y-1/2 w-4 h-4 text-slate-400 pointer-events-none"
      fill="none"
      stroke="currentColor"
      viewBox="0 0 24 24"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
      />
    </svg>
    <input
      type="search"
      id="search-input"
      placeholder="Search projects and posts..."
      autocomplete="off"
      class="w-full pl-10 pr-4 py-2.5 bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 rounded-xl text-slate-900 dark:text-slate-100 placeholder-slate-400 text-sm focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition-colors"
    />
  </div>

  <div
    id="search-results"
    class="absolute top-full left-0 w-full mt-2 bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-xl shadow-2xl hidden z-50 overflow-hidden divide-y divide-slate-100 dark:divide-slate-700"
  >
  </div>
</div>

<!-- type=module required for dynamic import() of Fuse from CDN -->
<script type="module" define:vars={{ searchData }}>
  (function () {
    const data = JSON.parse(searchData);
    const input = document.getElementById('search-input');
    const resultsEl = document.getElementById('search-results');
    if (!input || !resultsEl) return;

    // Simple substring search used before Fuse loads
    function simpleSearch(query) {
      const q = query.toLowerCase();
      return data
        .filter((item) => {
          const text = [item.title, item.description, ...(item.tags || [])].join(' ').toLowerCase();
          return text.includes(q);
        })
        .slice(0, 6);
    }

    let fuse = null;

    // Lazy-load Fuse.js via CDN for fuzzy matching
    import('https://cdn.jsdelivr.net/npm/fuse.js@7/dist/fuse.mjs')
      .then(({ default: Fuse }) => {
        fuse = new Fuse(data, {
          keys: ['title', 'description', 'tags'],
          threshold: 0.35,
          includeScore: true,
        });
      })
      .catch(() => {
        /* falls back to simpleSearch */
      });

    function renderResults(matches) {
      if (matches.length === 0) {
        resultsEl.innerHTML =
          '<div class="p-4 text-sm text-slate-500 dark:text-slate-400 text-center">No results found</div>';
      } else {
        resultsEl.innerHTML = matches
          .map(
            (item) => `
          <a
            href="${item.slug}"
            class="flex items-start gap-3 px-4 py-3 hover:bg-slate-50 dark:hover:bg-slate-700/50 transition-colors no-underline group"
          >
            <div class="flex-1 min-w-0">
              <div class="text-sm font-medium text-slate-900 dark:text-slate-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 truncate">
                ${item.title}
              </div>
              <div class="text-xs text-slate-500 dark:text-slate-400 truncate mt-0.5">
                ${item.description}
              </div>
            </div>
            <span class="text-xs text-slate-400 capitalize shrink-0 mt-0.5 bg-slate-100 dark:bg-slate-700 px-2 py-0.5 rounded-full">
              ${item.type}
            </span>
          </a>
        `
          )
          .join('');
      }
      resultsEl.classList.remove('hidden');
    }

    input.addEventListener('input', (e) => {
      const query = e.target.value.trim();
      if (query.length < 2) {
        resultsEl.classList.add('hidden');
        return;
      }
      const matches = fuse
        ? fuse.search(query).map((r) => r.item)
        : simpleSearch(query);
      renderResults(matches);
    });

    document.addEventListener('click', (e) => {
      if (!e.target.closest('#search-container')) {
        resultsEl.classList.add('hidden');
      }
    });

    input.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        resultsEl.classList.add('hidden');
        input.blur();
      }
    });
  })();
</script>
