---
import ProjectCard from './ProjectCard.astro';

interface Props {
  projects: Array<{
    id: string;
    data: {
      title: string;
      subtitle: string;
      year: number;
      tags: string[];
      thumbnail: string;
      published: boolean;
    };
  }>;
}

const { projects } = Astro.props;
---

{
  projects.length === 0 ? (
    <p class="text-slate-500 dark:text-slate-400 text-center py-12">No projects found.</p>
  ) : (
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
  )
}
