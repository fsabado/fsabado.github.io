---
interface Props {
  project: {
    slug: string;
    data: {
      title: string;
      subtitle: string;
      year: number;
      tags: string[];
      thumbnail: string;
    };
  };
}

const { project } = Astro.props;
const { title, subtitle, year, tags, thumbnail } = project.data;
---

<a href={`/projects/${project.slug}/`} class="group block no-underline hover:no-underline">
  <div class="card hover:shadow-lg transition-all duration-300 h-full flex flex-col">
    <!-- Thumbnail -->
    <div class="aspect-video overflow-hidden bg-slate-100 dark:bg-slate-700 shrink-0">
      <img
        src={thumbnail}
        alt={title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
        loading="lazy"
        decoding="async"
      />
    </div>

    <!-- Content -->
    <div class="p-6 flex flex-col flex-1">
      <div class="flex justify-between items-start gap-2 mb-2">
        <h3
          class="text-base font-bold text-slate-900 dark:text-slate-100 group-hover:text-blue-600 dark:group-hover:text-blue-400 transition-colors leading-snug"
        >
          {title}
        </h3>
        <span class="text-xs text-slate-400 dark:text-slate-500 shrink-0 mt-0.5">{year}</span>
      </div>

      <p class="text-sm text-slate-500 dark:text-slate-400 mb-4 flex-1">{subtitle}</p>

      <div class="flex flex-wrap gap-1.5">
        {tags.slice(0, 3).map((tag) => <span class="badge">{tag}</span>)}
        {tags.length > 3 && <span class="badge bg-slate-100 text-slate-600 dark:bg-slate-700 dark:text-slate-300">+{tags.length - 3}</span>}
      </div>
    </div>
  </div>
</a>
